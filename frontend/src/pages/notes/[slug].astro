---
// Article detail page — SSR dynamic route
// 查無文章時回傳 HTTP 404（見 frontend/docs/404-troubleshooting.md）
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotFoundPage from '../../components/NotFoundPage.astro';
import TableOfContents from '../../components/TableOfContents.vue';
import ArticleSyntaxHighlight from '../../components/ArticleSyntaxHighlight.vue';
import ArticleImageLightbox from '../../components/ArticleImageLightbox.vue';
import SectionHero from '../../components/SectionHero.astro';
import { backendFetchInit } from '../../lib/backendFetch';

const { slug } = Astro.params;
const apiBase = import.meta.env.API_BASE || 'http://backend:5000';
const beInit = backendFetchInit(Astro.request);

let article = null;
let error   = null;
let articleHero: { coverUrl?: string; title?: string; subtitle?: string } | null = null;

try {
  const [res, profRes] = await Promise.all([
    fetch(`${apiBase}/api/articles/${slug}`, beInit),
    fetch(`${apiBase}/api/site-profile`, beInit),
  ]);
  if (res.status === 401 || profRes.status === 401) {
    return Astro.redirect('/login?reason=session');
  }
  if (profRes.ok) {
    const pj = await profRes.json();
    articleHero = pj.data?.articleHero ?? null;
  }
  if (res.ok) {
    const json = await res.json();
    article = json.data;
  } else if (res.status === 404) {
    error = 'not_found';
  } else {
    error = 'server_error';
  }
} catch (e) {
  error = 'network_error';
}

if (!article && error === 'not_found') {
  Astro.response.status = 404;
}

function formatDate(iso: string | null): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '';
  return d.toLocaleDateString('zh-TW', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}

function plainText(input: string | null): string {
  if (!input) return '';
  return input
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
    .replace(/\[[^\]]*\]\([^)]+\)/g, ' ')
    .replace(/^#{1,6}\s*/gm, '')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/^\s*\d+\.\s+/gm, '')
    .replace(/<[^>]*>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function countReadableUnits(input: string | null): number {
  const text = plainText(input);
  if (!text) return 0;
  const cjkChars = (text.match(/[\u3400-\u9FFF]/g) || []).length;
  const nonCjk = text.replace(/[\u3400-\u9FFF]/g, ' ');
  const latinWords = (nonCjk.match(/[A-Za-z0-9_]+/g) || []).length;
  return cjkChars + latinWords;
}

function formatWordCount(units: number): string {
  if (units >= 1000) {
    const k = units / 1000;
    const fixed = k >= 10 ? k.toFixed(0) : k.toFixed(1);
    return `${fixed.replace(/\.0$/, '')}k`;
  }
  return String(units);
}

function estimateReadingMinutes(units: number): number {
  return Math.max(1, Math.ceil(units / 300));
}
---

{!article && error === 'not_found' ? (
  <NotFoundPage />
) : (
<BaseLayout
  title={article?.title ?? 'Article Not Found'}
  description={article?.description ?? ''}
  headerOverlay
>
  {!error && article && (
    <Fragment slot="hero">
      <SectionHero
        coverUrl={articleHero?.coverUrl}
        title={article.title}
        subtitle={articleHero?.subtitle}
        contentAnchor="#article-content-start"
        overlayHeader
      />
    </Fragment>
  )}
  {error ? (
    <div class="mx-auto w-full max-w-content px-4 py-12 md:px-6">
      <div class="rounded-xl border border-zinc-200 bg-white p-10 text-center text-zinc-600 shadow-sm dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-300">
        <p class="mb-3 text-5xl opacity-40">⚠</p>
        <h1 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100">無法載入文章</h1>
        <p class="mt-2">請確認 API 服務是否正常運行。</p>
        <a href="/" class="mt-5 inline-block rounded-full border border-accent px-5 py-2 text-sm font-semibold text-accent hover:bg-accent hover:text-white">← 返回首頁</a>
      </div>
    </div>
  ) : (
    <div id="article-content-start" class="mx-auto grid w-full max-w-[1280px] grid-cols-1 gap-6 px-4 py-8 md:px-6 xl:grid-cols-[280px_minmax(0,840px)] xl:justify-center">
      <!-- Table of Contents (Vue island) -->
      {article.html_content && (
        <aside class="hidden xl:block xl:sticky xl:top-20 xl:max-h-[calc(100vh-6rem)] xl:overflow-y-auto">
          <TableOfContents client:load htmlContent={article.html_content} />
        </aside>
      )}

      <div class="min-w-0">

          <!-- Breadcrumb -->
          <nav class="mb-5 flex flex-wrap items-center gap-1 text-sm text-zinc-500 dark:text-zinc-400" aria-label="Breadcrumb">
            <a href="/" class="hover:text-accent">首頁</a>
            {article.category?.slug ? (
              <>
                <span class="text-zinc-400">›</span>
                <a href={`/categories/${article.category.slug}`} class="hover:text-accent">{article.category.name}</a>
              </>
            ) : (
              <>
                <span class="text-zinc-400">›</span>
                <a href="/categories/_uncategorized" class="hover:text-accent">未分類</a>
              </>
            )}
            <span class="text-zinc-400">›</span>
            <span class="text-zinc-700 dark:text-zinc-300">{article.title}</span>
          </nav>

          <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm dark:border-zinc-700 dark:bg-zinc-900 md:p-8">
            <!-- Article header -->
            <header class="mb-6 border-b border-zinc-200 pb-5 dark:border-zinc-700">
              {article.category?.slug ? (
                <a href={`/categories/${article.category.slug}`} class="mb-2 inline-block text-xs font-semibold uppercase tracking-wide text-accent">
                  {article.category.name}
                </a>
              ) : (
                <a href="/categories/_uncategorized" class="mb-2 inline-block text-xs font-semibold uppercase tracking-wide text-accent">
                  未分類
                </a>
              )}
              <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">{article.title}</h1>
              {article.description && (
                <p class="mt-3 text-zinc-600 dark:text-zinc-400">{article.description}</p>
              )}
              {
                (() => {
                  const textUnits = countReadableUnits(article.content || article.description || article.title || '');
                  const readingMinutes = estimateReadingMinutes(textUnits);
                  return (
                    <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-sm text-zinc-500 dark:text-zinc-400">
                      <span class="inline-flex items-center gap-1.5">
                        <i class="ri-calendar-line text-base leading-none text-zinc-400 dark:text-zinc-500" aria-hidden="true"></i>
                        <span>發表於 {formatDate(article.published_at) || '—'}</span>
                      </span>
                      <span class="inline-flex items-center gap-1.5">
                        <i class="ri-folder-3-line text-base leading-none text-zinc-400 dark:text-zinc-500" aria-hidden="true"></i>
                        <span>
                          分類於{' '}
                          {article.category?.slug ? (
                            <a
                              href={`/categories/${article.category.slug}`}
                              class="text-accent underline decoration-accent/40 underline-offset-2 hover:decoration-accent"
                            >
                              {article.category.name || article.category.slug}
                            </a>
                          ) : (
                            <a
                              href="/categories/_uncategorized"
                              class="text-accent underline decoration-accent/40 underline-offset-2 hover:decoration-accent"
                            >
                              未分類
                            </a>
                          )}
                        </span>
                      </span>
                      <span class="inline-flex items-center gap-1.5">
                        <i class="ri-file-text-line text-base leading-none text-zinc-400 dark:text-zinc-500" aria-hidden="true"></i>
                        <span>文章字數 {formatWordCount(textUnits)}</span>
                      </span>
                      <span class="inline-flex items-center gap-1.5">
                        <i class="ri-time-line text-base leading-none text-zinc-400 dark:text-zinc-500" aria-hidden="true"></i>
                        <span>所需閱讀時間 {readingMinutes} 分鐘</span>
                      </span>
                    </div>
                  );
                })()
              }
              {article.tags?.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {article.tags.map((tag: any) => (
                    <a href={`/?tag=${tag.slug}`} class="rounded-full bg-zinc-100 px-2 py-0.5 text-xs text-zinc-600 hover:bg-accent/10 hover:text-accent dark:bg-zinc-800 dark:text-zinc-400">{tag.name}</a>
                  ))}
                </div>
              )}
              <div class="mt-4 h-[3px] w-20 rounded bg-gradient-to-r from-accent to-sky-300" aria-hidden="true"></div>
            </header>

            <!-- Markdown content -->
            <div
              id="article-body-content"
              class="article-body prose prose-zinc max-w-none dark:prose-invert prose-headings:scroll-mt-24 prose-a:text-accent prose-a:hover:text-sky-400 prose-pre:!m-0 prose-pre:!border-0 prose-pre:!bg-transparent prose-pre:!p-0 prose-pre:!shadow-none prose-img:rounded-lg prose-img:shadow-sm"
              set:html={article.html_content ?? '<p>無內容</p>'}
            />
            {article.html_content && <ArticleSyntaxHighlight client:load />}

            <!-- Footer nav -->
            <footer class="mt-8 border-t border-zinc-200 pt-5 dark:border-zinc-700">
              <a href="/" class="text-sm font-medium text-zinc-500 hover:text-accent">← 返回文章列表</a>
            </footer>
          </article>
          <!-- 燈箱掛在 article 外，避免 fixed 被父層裁切；client:only 避免 Vue hydration mismatch -->
          {article.html_content && <ArticleImageLightbox client:only="vue" />}
      </div>
    </div>
  )}
</BaseLayout>
)}

<style>
  /* 避免文章正文與右側目錄重複顯示同一份 TOC */
  :global(.article-body .toc) {
    display: none;
  }
</style>
