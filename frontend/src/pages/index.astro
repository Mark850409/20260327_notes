---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.vue';

const apiBase = import.meta.env.API_BASE || 'http://backend:5000';
const siteTitle = import.meta.env.PUBLIC_SITE_TITLE || 'My Notes';
const siteDesc = import.meta.env.PUBLIC_SITE_DESCRIPTION || '';

const url = Astro.url;
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10) || 1);
const q = url.searchParams.get('q')?.trim() || '';
const tag = url.searchParams.get('tag')?.trim() || '';

let articles: any[] = [];
let categories: any[] = [];
let totalCount = 0;
let totalPages = 1;
let postsPerPage = 10;

try {
  const profRes = await fetch(`${apiBase}/api/site-profile`);
  if (profRes.ok) {
    const j = await profRes.json();
    const n = Number(j.data?.postsPerPage);
    if (Number.isFinite(n) && n >= 1 && n <= 50) postsPerPage = Math.floor(n);
  }
} catch (e) {}

const qs = new URLSearchParams();
qs.set('page', String(page));
qs.set('limit', String(postsPerPage));
if (q) qs.set('q', q);
if (tag) qs.set('tag', tag);

try {
  const [artRes, catRes] = await Promise.all([
    fetch(`${apiBase}/api/articles?${qs.toString()}`),
    fetch(`${apiBase}/api/categories`),
  ]);
  if (artRes.ok) {
    const j = await artRes.json();
    articles = j.data || [];
    totalCount = j.meta?.total ?? 0;
    totalPages = Math.max(1, j.meta?.pages ?? 1);
  }
  if (catRes.ok) {
    const j = await catRes.json();
    categories = j.data || [];
  }
} catch (e) {}

function formatDate(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('zh-TW', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function pageHref(p: number): string {
  const x = new URLSearchParams();
  if (p > 1) x.set('page', String(p));
  if (q) x.set('q', q);
  if (tag) x.set('tag', tag);
  const s = x.toString();
  return s ? `/?${s}` : '/';
}

function summaryText(input: string | null): string {
  if (!input) return '';
  return input
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
    .replace(/\[[^\]]*\]\([^)]+\)/g, ' ')
    .replace(/^#{1,6}\s*/gm, '')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/^\s*\d+\.\s+/gm, '')
    .replace(/\s+/g, ' ')
    .trim();
}
---

<BaseLayout title={siteTitle} description={siteDesc}>
  <div class="mx-auto w-full max-w-content px-4 py-8 pb-16 md:px-6">
    <div class="mb-6 text-sm text-zinc-500">
      {totalCount} 篇文章 · {categories.length} 個分類 · 每頁 {postsPerPage} 篇
      {q && ` · 搜尋：「${q}」`}
      {tag && ` · 標籤：${tag}`}
    </div>

    <div class="mb-6">
      <SearchBox client:load apiBase={apiBase} />
    </div>

    {
      categories.length > 0 && (
        <nav class="mb-8 flex flex-wrap gap-2" aria-label="分類">
          <a
            href={tag || q ? '/' : '/'}
            class:list={[
              'inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium transition-colors',
              !tag && !q
                ? 'border-accent bg-accent text-white'
                : 'border-zinc-300 bg-white text-zinc-600 hover:border-accent hover:text-accent dark:border-zinc-600 dark:bg-zinc-900 dark:text-zinc-400',
            ]}
          >
            全部
          </a>
          {categories.map((cat: any) => (
            <a
              href={`/categories/${cat.slug}`}
              class="inline-flex items-center rounded-full border border-zinc-300 bg-white px-3 py-1 text-sm font-medium text-zinc-600 transition-colors hover:border-accent hover:text-accent dark:border-zinc-600 dark:bg-zinc-900 dark:text-zinc-400"
            >
              {cat.name}
            </a>
          ))}
        </nav>
      )
    }

    <section class="flex flex-col gap-5" aria-label="文章列表">
      {
        articles.length === 0 ? (
          <div class="rounded-xl border border-dashed border-zinc-300 bg-white p-12 text-center text-zinc-500 shadow-sm dark:border-zinc-700 dark:bg-zinc-900">
            <p class="mb-2 text-4xl opacity-40">⊘</p>
            <p>尚無文章。請登入 Strapi CMS 後台新增內容。</p>
            <a
              href="/admin"
              class="mt-4 inline-block rounded-full border border-accent px-4 py-2 text-sm font-medium text-accent hover:bg-accent/10"
            >
              前往 CMS 後台
            </a>
          </div>
        ) : (
          articles.map((article: any) => (
            <article class="flex flex-col rounded-xl border border-zinc-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-sky-300/80 hover:shadow-md dark:border-zinc-700 dark:bg-zinc-900">
              {article.category && (
                <a
                  href={`/categories/${article.category.slug}`}
                  class="mb-2 text-xs font-semibold uppercase tracking-wide text-accent"
                >
                  {article.category.name}
                </a>
              )}
              <h2 class="text-xl font-bold text-zinc-900 dark:text-zinc-50">
                <a href={`/notes/${article.slug}`} class="hover:text-accent">
                  {article.title}
                </a>
              </h2>
              {article.description && (
                <p class="mt-3 line-clamp-3 text-zinc-600 dark:text-zinc-400">{summaryText(article.description)}</p>
              )}
              <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-zinc-100 pt-4 dark:border-zinc-800">
                <span class="text-xs text-zinc-500">{formatDate(article.published_at)}</span>
                <div class="flex flex-wrap items-center gap-2">
                  {article.tags?.slice(0, 4).map((t: any) => (
                    <a
                      href={`/?tag=${encodeURIComponent(t.slug)}`}
                      class="rounded-full bg-zinc-100 px-2 py-0.5 text-xs text-zinc-600 hover:bg-accent/15 hover:text-accent dark:bg-zinc-800 dark:text-zinc-400"
                    >
                      {t.name}
                    </a>
                  ))}
                  <a
                    href={`/notes/${article.slug}`}
                    class="rounded-full bg-accent px-4 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-sky-500"
                  >
                    閱讀更多
                  </a>
                </div>
              </div>
            </article>
          ))
        )
      }
    </section>

    {
      totalPages > 1 && articles.length > 0 && (
        <nav
          class="mt-10 flex flex-wrap items-center justify-center gap-2 border-t border-zinc-200 pt-8 dark:border-zinc-800"
          aria-label="分頁"
        >
          {page > 1 ? (
            <a
              href={pageHref(page - 1)}
              class="rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 hover:border-accent hover:text-accent dark:border-zinc-600 dark:bg-zinc-900"
            >
              上一頁
            </a>
          ) : (
            <span class="cursor-not-allowed rounded-lg border border-transparent px-4 py-2 text-sm text-zinc-400">
              上一頁
            </span>
          )}
          <span class="px-3 text-sm text-zinc-600 dark:text-zinc-400">
            第 {page} / {totalPages} 頁
          </span>
          {page < totalPages ? (
            <a
              href={pageHref(page + 1)}
              class="rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 hover:border-accent hover:text-accent dark:border-zinc-600 dark:bg-zinc-900"
            >
              下一頁
            </a>
          ) : (
            <span class="cursor-not-allowed rounded-lg border border-transparent px-4 py-2 text-sm text-zinc-400">
              下一頁
            </span>
          )}
        </nav>
      )
    }
  </div>
</BaseLayout>
