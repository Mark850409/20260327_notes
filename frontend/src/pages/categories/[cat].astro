---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { backendFetchInit } from '../../lib/backendFetch';

const { cat } = Astro.params;
const apiBase = import.meta.env.API_BASE || 'http://backend:5000';
const beInit = backendFetchInit(Astro.request);

const url = Astro.url;
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10) || 1);

let articles: any[] = [];
let category: any = null;
let totalCount = 0;
let totalPages = 1;
let postsPerPage = 10;

try {
  const profRes = await fetch(`${apiBase}/api/site-profile`, beInit);
  if (profRes.status === 401) {
    return Astro.redirect('/login?reason=session');
  }
  if (profRes.ok) {
    const j = await profRes.json();
    const n = Number(j.data?.postsPerPage);
    if (Number.isFinite(n) && n >= 1 && n <= 50) postsPerPage = Math.floor(n);
  }
} catch (e) {}

try {
  const [artRes, catRes] = await Promise.all([
    fetch(`${apiBase}/api/articles?category=${cat}&page=${page}&limit=${postsPerPage}`, beInit),
    fetch(`${apiBase}/api/categories`, beInit),
  ]);
  if (artRes.status === 401 || catRes.status === 401) {
    return Astro.redirect('/login?reason=session');
  }
  if (artRes.ok) {
    const j = await artRes.json();
    articles = j.data || [];
    totalCount = j.meta?.total ?? 0;
    totalPages = Math.max(1, j.meta?.pages ?? 1);
  }
  if (catRes.ok) {
    const j = await catRes.json();
    category = j.data?.find((c: any) => c.slug === cat) || null;
  }
} catch (e) {}

function formatDate(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
}

function pageHref(p: number): string {
  if (p <= 1) return `/categories/${cat}`;
  return `/categories/${cat}?page=${p}`;
}
---

<BaseLayout title={category?.name ?? cat}>
  <div class="mx-auto w-full max-w-content px-4 py-8 pb-16 md:px-6">
    <nav
      class="mb-6 flex flex-wrap items-center gap-1 text-sm text-zinc-500 dark:text-zinc-400"
      aria-label="breadcrumb"
    >
      <a href="/" class="hover:text-accent">首頁</a>
      <span class="text-zinc-400">›</span>
      <span class="text-zinc-700 dark:text-zinc-300">{category?.name ?? cat}</span>
    </nav>

    <header
      class="mb-8 rounded-xl border border-sky-200/60 bg-gradient-to-br from-sky-100/80 to-transparent p-6 shadow-sm dark:border-sky-500/20 dark:from-sky-950/40"
    >
      <p class="text-xs font-semibold uppercase tracking-wide text-accent">分類</p>
      <h1 class="mt-1 text-2xl font-bold text-zinc-900 dark:text-zinc-50">{category?.name ?? cat}</h1>
      <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
        {totalCount} 篇文章 · 每頁 {postsPerPage} 篇
      </p>
    </header>

    <section class="flex flex-col gap-5" aria-label="文章列表">
      {
        articles.map((article: any) => (
          <article class="flex flex-col rounded-xl border border-zinc-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-sky-300/80 hover:shadow-md dark:border-zinc-700 dark:bg-zinc-900">
            <h2 class="text-xl font-bold text-zinc-900 dark:text-zinc-50">
              <a href={`/notes/${article.slug}`} class="hover:text-accent">
                {article.title}
              </a>
            </h2>
            {article.description && (
              <p class="mt-3 line-clamp-3 text-zinc-600 dark:text-zinc-400">{article.description}</p>
            )}
            <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-zinc-100 pt-4 dark:border-zinc-800">
              <span class="text-xs text-zinc-500">{formatDate(article.published_at)}</span>
              <a
                href={`/notes/${article.slug}`}
                class="rounded-full bg-accent px-4 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-sky-500"
              >
                閱讀更多
              </a>
            </div>
          </article>
        ))
      }
      {
        articles.length === 0 && (
          <p class="rounded-xl border border-dashed border-zinc-300 bg-zinc-50 py-12 text-center text-zinc-500 dark:border-zinc-700 dark:bg-zinc-900/50">
            此分類暫無文章。
          </p>
        )
      }
    </section>

    {
      totalPages > 1 && articles.length > 0 && (
        <nav
          class="mt-10 flex flex-wrap items-center justify-center gap-2 border-t border-zinc-200 pt-8 dark:border-zinc-800"
          aria-label="分頁"
        >
          {page > 1 ? (
            <a
              href={pageHref(page - 1)}
              class="rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 hover:border-accent hover:text-accent dark:border-zinc-600 dark:bg-zinc-900"
            >
              上一頁
            </a>
          ) : (
            <span class="cursor-not-allowed rounded-lg px-4 py-2 text-sm text-zinc-400">上一頁</span>
          )}
          <span class="px-3 text-sm text-zinc-600 dark:text-zinc-400">
            第 {page} / {totalPages} 頁
          </span>
          {page < totalPages ? (
            <a
              href={pageHref(page + 1)}
              class="rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 hover:border-accent hover:text-accent dark:border-zinc-600 dark:bg-zinc-900"
            >
              下一頁
            </a>
          ) : (
            <span class="cursor-not-allowed rounded-lg px-4 py-2 text-sm text-zinc-400">下一頁</span>
          )}
        </nav>
      )
    }
  </div>
</BaseLayout>
