---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.vue';
import ThemeToggle from '../components/ThemeToggle.vue';
import { backendFetchInit } from '../lib/backendFetch';

interface Props {
  title?: string;
  description?: string;
  showSidebar?: boolean;
  headerOverlay?: boolean;
}

const {
  title = import.meta.env.PUBLIC_SITE_TITLE || 'My Notes',
  description = import.meta.env.PUBLIC_SITE_DESCRIPTION || 'A personal knowledge base',
  showSidebar = true,
  headerOverlay = false,
} = Astro.props;

const siteTitle = import.meta.env.PUBLIC_SITE_TITLE || 'My Notes';
const apiBase = import.meta.env.API_BASE || 'http://backend:5000';
const beInit = backendFetchInit(Astro.request);

let categories: any[] = [];
let siteProfile: Record<string, any> = {};
let recentArticles: any[] = [];
let stats = { posts: 0, categories: 0, tags: 0 };

try {
  const [profRes, artMetaRes, catRes, tagRes, recentRes] = await Promise.all([
    fetch(`${apiBase}/api/site-profile`, beInit),
    fetch(`${apiBase}/api/articles?page=1&limit=1`, beInit),
    fetch(`${apiBase}/api/categories`, beInit),
    fetch(`${apiBase}/api/tags`, beInit),
    fetch(`${apiBase}/api/articles?page=1&limit=5`, beInit),
  ]);

  if (profRes.ok) {
    const j = await profRes.json();
    siteProfile = j.data || {};
  }
  if (artMetaRes.ok) {
    const j = await artMetaRes.json();
    stats.posts = j.meta?.total ?? 0;
  }
  if (catRes.ok) {
    const j = await catRes.json();
    categories = j.data || [];
    stats.categories = categories.length;
  }
  if (tagRes.ok) {
    const j = await tagRes.json();
    stats.tags = (j.data || []).length;
  }
  if (recentRes.ok) {
    const j = await recentRes.json();
    recentArticles = j.data || [];
  }
} catch (e) {
  // fail silently
}
---

<!DOCTYPE html>
<html lang="zh-TW" data-theme="light">
  <head>
    <script is:inline>
      try {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || t === 'light') document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === siteTitle ? title : `${title} — ${siteTitle}`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/remixicon@4.6.0/fonts/remixicon.min.css"
    />
    <!-- Privacy-friendly analytics by Plausible -->
    <script async src="https://plausible.io/js/pa-qFRVyxqJaj0TOigZMvd51.js"></script>
    <script>
      window.plausible = window.plausible || function () {
        (plausible.q = plausible.q || []).push(arguments);
      }, plausible.init = plausible.init || function (i) {
        plausible.o = i || {};
      };
      plausible.init();
    </script>
  </head>
  <body
    class="min-h-screen bg-zinc-100 text-zinc-900 transition-colors dark:bg-zinc-950 dark:text-zinc-100"
  >
    <div class="min-h-screen">
      <div class="relative">
        <header
          class:list={[
            'z-[5] flex min-h-14 flex-wrap items-center gap-x-2 gap-y-2 px-3 py-2 md:px-4',
            headerOverlay
              ? 'absolute inset-x-0 top-0 border-b border-white/15 bg-zinc-950/30 text-white backdrop-blur-md'
              : 'sticky top-0 border-b border-zinc-200 bg-white shadow-sm dark:border-zinc-800 dark:bg-zinc-900',
          ]}
        >
          <nav
            class="flex min-w-0 max-w-full flex-1 flex-wrap items-center gap-x-1 gap-y-1 overflow-x-auto pb-0.5 [-ms-overflow-style:none] [scrollbar-width:none] md:gap-x-2 [&::-webkit-scrollbar]:hidden"
            aria-label="主導覽"
          >
            <a
              href="/"
              class:list={[
                'shrink-0 whitespace-nowrap rounded-lg px-2 py-1.5 text-sm font-medium transition-colors',
                headerOverlay
                  ? 'text-white/95 hover:bg-white/15 hover:text-white'
                  : 'text-zinc-700 hover:bg-zinc-100 hover:text-accent dark:text-zinc-200 dark:hover:bg-zinc-800 dark:hover:text-accent',
              ]}
            >
              技術筆記
            </a>
            <a
              href="/blog"
              class:list={[
                'shrink-0 whitespace-nowrap rounded-lg px-2 py-1.5 text-sm font-medium transition-colors',
                headerOverlay
                  ? 'text-white/95 hover:bg-white/15 hover:text-white'
                  : 'text-zinc-700 hover:bg-zinc-100 hover:text-accent dark:text-zinc-200 dark:hover:bg-zinc-800 dark:hover:text-accent',
              ]}
            >
              部落格
            </a>
            <a
              href="/admin"
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                'shrink-0 whitespace-nowrap rounded-lg px-2 py-1.5 text-sm font-medium transition-colors',
                headerOverlay
                  ? 'text-white/90 hover:bg-white/15 hover:text-white'
                  : 'text-zinc-600 hover:bg-zinc-100 hover:text-accent dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-accent',
              ]}
            >
              CMS
            </a>
          </nav>
          <div class="ml-auto flex shrink-0 items-center gap-2">
            <button
              type="button"
              id="notes-logout"
              class:list={[
                'rounded-lg px-2 py-1.5 text-sm',
                headerOverlay
                  ? 'text-zinc-100/95 hover:bg-white/15 hover:text-white'
                  : 'text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100',
              ]}
            >
              登出
            </button>
            <ThemeToggle client:load overlay={headerOverlay} />
          </div>
        </header>
        <slot name="hero" />
      </div>

      <div class="mx-auto flex w-full max-w-[1320px] flex-col md:flex-row md:items-start md:gap-6 md:px-4">
        {showSidebar && (
          <Sidebar
            client:load
            categories={categories}
            siteTitle={siteTitle}
            profile={siteProfile}
            recentArticles={recentArticles}
            stats={stats}
          />
        )}
        <main class="main min-w-0 flex-1 bg-zinc-100 dark:bg-zinc-950" id="main-content">
          <slot />
        </main>
      </div>
    </div>

    <script>
      document.getElementById('notes-logout')?.addEventListener('click', async () => {
        try {
          await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
        } catch {
          /* ignore */
        }
        try {
          localStorage.removeItem('notes_session');
        } catch {
          /* ignore */
        }
        window.location.href = '/login';
      });
    </script>
  </body>
</html>
