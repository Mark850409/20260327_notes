---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.vue';
import ThemeToggle from '../components/ThemeToggle.vue';

interface Props {
  title?: string;
  description?: string;
  showSidebar?: boolean;
}

const {
  title = import.meta.env.PUBLIC_SITE_TITLE || 'My Notes',
  description = import.meta.env.PUBLIC_SITE_DESCRIPTION || 'A personal knowledge base',
  showSidebar = true,
} = Astro.props;

const siteTitle = import.meta.env.PUBLIC_SITE_TITLE || 'My Notes';
const apiBase = import.meta.env.API_BASE || 'http://backend:5000';

let categories: any[] = [];
let siteProfile: Record<string, any> = {};
let recentArticles: any[] = [];
let stats = { posts: 0, categories: 0, tags: 0 };

try {
  const [profRes, artMetaRes, catRes, tagRes, recentRes] = await Promise.all([
    fetch(`${apiBase}/api/site-profile`),
    fetch(`${apiBase}/api/articles?page=1&limit=1`),
    fetch(`${apiBase}/api/categories`),
    fetch(`${apiBase}/api/tags`),
    fetch(`${apiBase}/api/articles?page=1&limit=5`),
  ]);

  if (profRes.ok) {
    const j = await profRes.json();
    siteProfile = j.data || {};
  }
  if (artMetaRes.ok) {
    const j = await artMetaRes.json();
    stats.posts = j.meta?.total ?? 0;
  }
  if (catRes.ok) {
    const j = await catRes.json();
    categories = j.data || [];
    stats.categories = categories.length;
  }
  if (tagRes.ok) {
    const j = await tagRes.json();
    stats.tags = (j.data || []).length;
  }
  if (recentRes.ok) {
    const j = await recentRes.json();
    recentArticles = j.data || [];
  }
} catch (e) {
  // fail silently
}
---

<!DOCTYPE html>
<html lang="zh-TW" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === siteTitle ? title : `${title} — ${siteTitle}`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body
    class="min-h-screen bg-zinc-100 text-zinc-900 transition-colors dark:bg-zinc-950 dark:text-zinc-100"
  >
    <div class="flex min-h-screen">
      {showSidebar && (
        <Sidebar
          client:load
          categories={categories}
          siteTitle={siteTitle}
          profile={siteProfile}
          recentArticles={recentArticles}
          stats={stats}
        />
      )}
      <main class="main min-w-0 flex-1 bg-zinc-100 dark:bg-zinc-950" id="main-content">
        <header
          class="sticky top-0 z-[5] flex h-14 items-center justify-between border-b border-zinc-200 bg-white px-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900"
        >
          <button
            class="menu-toggle flex rounded-lg p-2 text-zinc-500 hover:bg-zinc-100 hover:text-accent md:hidden"
            id="menu-toggle"
            type="button"
            aria-label="開啟側欄"
          >
            <span class="text-xl leading-none" aria-hidden="true">☰</span>
          </button>
          <div class="ml-auto flex items-center gap-2">
            <ThemeToggle client:load />
          </div>
        </header>

        <slot />
      </main>
    </div>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const sidebar = document.querySelector('.sidebar');
      toggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        sidebar?.classList.toggle('open');
      });
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (
          window.matchMedia('(max-width: 767px)').matches &&
          sidebar?.classList.contains('open') &&
          target !== toggle &&
          !(target instanceof Node && sidebar?.contains(target))
        ) {
          sidebar.classList.remove('open');
        }
      });
    </script>
  </body>
</html>
