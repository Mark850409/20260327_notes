# ============================================================
# Notes Site — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Docker 對外埠號（NAS／主機與其他服務衝突時改左側主機埠；右側容器內埠固定）──
# 範例：NGINX_HTTP_PORT=8080 則瀏覽器用 http://nas:8080
MYSQL_HOST_PORT=3306
BACKEND_HOST_PORT=5000
NGINX_HTTP_PORT=80
STRAPI_HTTP_PORT=1337
STRAPI_ADMIN_VITE_PORT=24678
FRONTEND_HOST_PORT=4321

# ── MySQL ──────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=strapi_db
MYSQL_USER=strapi
MYSQL_PASSWORD=strapipassword

# ── Strapi ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
STRAPI_JWT_SECRET=your-jwt-secret-change-me
STRAPI_ADMIN_JWT_SECRET=your-admin-jwt-secret-change-me
STRAPI_API_TOKEN_SALT=your-token-salt-change-me
STRAPI_APP_KEYS=key1-change-me,key2-change-me
STRAPI_TRANSFER_TOKEN_SALT=your-transfer-token-salt-change-me
# 前台「使用者與權限」JWT 效期（預設 90d；過期後須重新登入）
# STRAPI_USERS_JWT_EXPIRES_IN=90d

# ── OpenAI（批次匯入「AI 自動分類」）──────────────────────────
# 在 Strapi 容器內讀取；未設定時會退回路徑/未分類並標記 openai-missing-key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 內嵌圖片轉媒體庫：單張大小上限（bytes），預設 5242880（5MB）
INLINE_IMAGE_MAX_BYTES=5242880

# ── MinIO（批次匯入 Markdown 時，將 ![](相對路徑) 圖片上傳並替換為公開 URL）──
# Strapi 容器內連線位址；與 docker-compose 一併使用時預設為 http://minio:9000
# MINIO_ENDPOINT=http://minio:9000
# 瀏覽器／前台可存取的基礎 URL（路徑樣式：{PUBLIC}/{BUCKET}/{key}）。
# 若只在「執行瀏覽器的同一台電腦」預覽可用 localhost；手機／其他電腦請改為主機 IP、DDNS 或經 Nginx 反代的網址（勿填容器內 minio:9000）。
# MINIO_PUBLIC_URL=http://localhost:9000
# 後台「預覽」內嵌圖需符合 CSP；會依 MINIO_PUBLIC_URL 自動加入 img-src。若仍無法顯示可再加：
# STRAPI_CSP_MEDIA_ORIGINS=http://localhost:9000,http://127.0.0.1:9000
# MINIO_BUCKET=notes-media
# 匯入時自動套用 bucket 匿名讀取政策（否則瀏覽器開圖會 AccessDenied）；若桶必須完全私有請設 false 並改用自己簽網址／反代
# MINIO_BUCKET_PUBLIC_READ=true
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_REGION=us-east-1
# Docker 對外埠（見 docker-compose 中 minio 服務）
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# BookStack 等遠端圖片：下載前將舊網域換成新站再抓取（程式內建預設如下，可改）
# MINIO_REMOTE_SRC_URL_PREFIX=https://zanehsu.myqnapcloud.com:6876
# MINIO_REMOTE_DST_URL_PREFIX=https://bookstack.zanehsu.site
# 設為 0 可關閉「遠端網址下載」，只保留相對路徑本機圖片
# MINIO_REMOTE_DOWNLOAD=1
# 遠端單張上限（未設則沿用 INLINE_IMAGE_MAX_BYTES）
# MINIO_REMOTE_MAX_BYTES=10485760

# 文章「擁有者」預設為 users-permissions 的使用者 id（數字）。後台手動建立／批次匯入未填 owner 時會套用；前台僅能讀到與 JWT 相同 owner 的文章。
# STRAPI_DEFAULT_ARTICLE_OWNER_ID=1

# 後台內容管理依「管理員 email = API User email」只顯示該 owner 的文章／分類（超級管理員除外）。除錯可設 true 關閉。
# STRAPI_CM_OWNER_SCOPE_DISABLED=false

# Strapi Admin（可選）：設為 true 可關閉 Vite HMR（F12 安靜但改 admin 要手動重整）
# Docker 已映射 24678:24678 + vite host 0.0.0.0，一般可保留熱更新
# STRAPI_ADMIN_DISABLE_HMR=

# Strapi Admin Vite 6+：經 NAS / DDNS 存取時若出現「Blocked request / allowedHosts」：
# 留空或不寫＝允許所有 Host（預設，適合內網 NAS）。
# 白名單（逗號分隔）：STRAPI_ADMIN_ALLOWED_HOSTS=zanehsu.myqnapcloud.com,localhost
# 改回 Vite 預設嚴格檢查：STRAPI_ADMIN_ALLOWED_HOSTS=strict
# STRAPI_ADMIN_ALLOWED_HOSTS=

# ── Flask Backend ───────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
# 登入 Cookie（notes_auth）是否加 Secure：
# - 不設定或留空＝auto：偵測 X-Forwarded-Proto: https 或 request.is_secure（NAS 經 HTTPS 建議用此，且 Nginx 需轉發 Proto，專案 nginx.conf 已處理）
# - 1＝一律 Secure（僅適合全程 HTTPS 存取）
# - 0＝一律不帶 Secure（僅 http:// 內網 IP:port 存取時使用；若瀏覽器網址列是 https 卻設 0，部分瀏覽器仍可能異常）
# FLASK_COOKIE_SECURE=
# 登入 Cookie 有效秒數（預設 30 天）
# NOTES_AUTH_COOKIE_MAX_AGE=2592000
# Flask reads from the SAME strapi_db (read-only)
DATABASE_URL=mysql+pymysql://strapi:strapipassword@mysql:3306/strapi_db

# ── Astro Frontend ──────────────────────────────────────────
# Used at build time and runtime (SSR)
API_BASE=http://backend:5000
PUBLIC_SITE_TITLE=My Notes
PUBLIC_SITE_DESCRIPTION=A personal knowledge base powered by Strapi + Flask + Astro

# Strapi 後台／公開網址（若改 STRAPI_HTTP_PORT，請同步改成 http://主機:新埠）
# STRAPI_PUBLIC_URL=http://localhost:1337
